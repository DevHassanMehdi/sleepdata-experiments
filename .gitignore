# =============================================================================
# .gitignore — sleepdata-experiments
# =============================================================================

# Data directories (datasets are large; download separately)
data/

# Pipeline outputs (regenerated by scripts)
outputs/

# Log files (regenerated at runtime)
logs/

# Downloaded archives
*.zip

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment files
.env
config_secret.py

# macOS metadata
.DS_Store

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Virtual environments
venv/
.venv/
env/

# IDE settings
.vscode/
.idea/
